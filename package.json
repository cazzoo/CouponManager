{
  "name": "coupon-manager",
  "version": "1.0.0",
  "description": "A web application to manage vouchers and coupons",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "dev:fresh": "bash scripts/dev-fresh.sh",
    "build": "vite build",
    "preview": "vite preview",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "cy:open": "cypress open",
    "cy:run": "cypress run",
    "cy:run:e2e": "cypress run --e2e",
    "cy:run:component": "cypress run --component",
    "test:e2e": "start-server-and-test dev http://localhost:5173 cy:run",
    "generate-diagrams": "node scripts/generate-diagrams.js",
    "docs": "pnpm generate-diagrams",
    "db:test": "node scripts/test-db-connection.js",
    "db:mock": "node scripts/add-mock-data.js",
    "migrate": "node scripts/run-sql-migrations.js",
    "migrate:up": "node scripts/run-sql-migrations.js up",
    "migrate:list": "node scripts/run-sql-migrations.js list",
    "migrate:status": "node scripts/run-sql-migrations.js status",
    "migrate:create": "node scripts/create-migration.js",
    "pb:start": "./thirdparty/pocketbase/pocketbase-darwin-arm64 serve --http=0.0.0.0:8090",
    "pb:setup": "node scripts/pocketbase-setup.mjs",
    "pb:create-collections": "node scripts/pocketbase-create-collections.mjs",
    "pb:reset": "node scripts/pocketbase-reset.mjs",
    "db:seed": "node scripts/pocketbase-seed-data.mjs",
    "setup:thirdparty": "bash scripts/setup-thirdparty.sh"
  },
  "dependencies": {
    "@supabase/supabase-js": "^2.49.1",
    "date-fns": "^2.30.0",
    "dotenv": "^16.4.7",
    "i18next": "^24.2.2",
    "i18next-browser-languagedetector": "^8.0.4",
    "lucide-react": "^0.563.0",
    "pg": "^8.11.3",
    "pocketbase": "^0.26.8",
    "prop-types": "^15.8.1",
    "react": "^18.2.0",
    "react-day-picker": "^9.13.0",
    "react-dom": "^18.2.0",
    "react-i18next": "^15.4.1",
    "react-qr-reader": "3.0.0-beta-1",
    "uuid": "^11.1.0",
    "zustand": "^5.0.11"
  },
  "devDependencies": {
    "@babel/core": "^7.29.0",
    "@babel/preset-env": "^7.29.0",
    "@cypress/code-coverage": "3.12.0",
    "@cypress/react18": "^2.0.1",
    "@cypress/vite-dev-server": "^7.2.0",
    "@mermaid-js/mermaid-cli": "^11.4.2",
    "@tailwindcss/postcss": "^4.1.18",
    "@tailwindcss/vite": "^4.1.18",
    "@testing-library/jest-dom": "^6.6.3",
    "@testing-library/react": "^16.2.0",
    "@testing-library/user-event": "^14.6.1",
    "@types/node": "^20",
    "@types/pg": "^8.10.9",
    "@types/react": "^18",
    "@types/react-dom": "^18",
    "@types/uuid": "^10.0.0",
    "@vitejs/plugin-react": "^4.2.0",
    "@vitest/coverage-v8": "3.0.7",
    "autoprefixer": "^10.0.1",
    "babel-plugin-istanbul": "^7.0.1",
    "cross-env": "^7.0.3",
    "cypress": "15.9.0",
    "daisyui": "^4.12.14",
    "eslint": "^8",
    "eslint-config-next": "14.0.4",
    "jsdom": "^26.0.0",
    "msw": "^2.7.3",
    "postcss": "^8",
    "start-server-and-test": "^2.1.3",
    "tailwindcss": "^3.4.17",
    "typescript": "^5",
    "vite": "^5.0.0",
    "vite-plugin-istanbul": "^7.2.1",
    "vitest": "^3.0.7"
  },
  "browserslist": {
    "production": [
      ">0.2%",
      "not dead",
      "not op_mini all"
    ],
    "development": [
      "last 1 chrome version",
      "last 1 firefox version",
      "last 1 safari version"
    ]
  },
  "msw": {
    "workerDirectory": [
      "public"
    ]
  }
}